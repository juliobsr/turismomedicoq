{
  "name": "medical-tourism",
  "version": "1.0.0",
  "description": "Enterprise Medical Tourism Platform - Headless Payload CMS v3 + Next.js",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "scripts": {
    "build": "npm run build:local",
    "build:local": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "deploy:local": "npm run build:local && npm run start:local",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh  --webpack",
    "devsafe": "npx rimraf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "db:create-migration": "payload migrate:create",
    "db:migrate": "payload migrate",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "npm run start:local",
    "start:local": "cross-env NODE_OPTIONS=--no-deprecation next start --port 3000",
    "test": "npm run test:int && npm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/email-resend": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-vercel-blob": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@tailwindcss/typography": "0.5.19",
    "@vercel/blob": "^2.3.3",
    "cross-env": "7.0.3",
    "dotenv": "16.4.7",
    "graphql": "16.8.1",
    "next": "16.2.2",
    "payload": "3.84.1",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "yet-another-react-lightbox": "3.32.0",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.1",
    "jsdom": "28.0.0",
    "postcss": "^8.5.9",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.19",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "@payloadcms/ui": "$@payloadcms/ui",
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
